{
  "name": "html-overlay-node",
  "version": "1.0.0",
  "description": "Zero-dependency visual node editor — Canvas rendering + HTML/CSS widget overlay. Data-flow graphs, workflow editors, visual scripting. Undo/redo, minimap, sub-graphs, TypeScript support.",
  "main": "./dist/html-overlay-node.umd.js",
  "module": "./dist/html-overlay-node.es.js",
  "types": "./index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/html-overlay-node.es.js",
      "require": "./dist/html-overlay-node.umd.js"
    },
    "./nodes": {
      "types": "./index.d.ts",
      "import": "./src/nodes/index.js",
      "require": "./src/nodes/index.js"
    },
    "./defaults": {
      "types": "./index.d.ts",
      "import": "./src/defaults/index.js",
      "require": "./src/defaults/index.js"
    },
    "./index.css": "./index.css",
    "./src/ui/PropertyPanel.css": "./src/ui/PropertyPanel.css"
  },
  "files": [
    "dist",
    "src",
    "index.css",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"*.md\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.js\" \"*.md\" \"*.json\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "node-editor",
    "visual-node-editor",
    "graph-editor",
    "visual-programming",
    "visual-scripting",
    "flow-based-programming",
    "data-flow",
    "workflow",
    "canvas",
    "html-overlay",
    "canvas-html-hybrid",
    "node-graph",
    "zero-dependencies",
    "undo-redo",
    "typescript",
    "litegraph-alternative",
    "rete-alternative"
  ],
  "author": "cheonghakim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cheonghakim/html-overlay-node.git"
  },
  "bugs": {
    "url": "https://github.com/cheonghakim/html-overlay-node/issues"
  },
  "homepage": "https://github.com/cheonghakim/html-overlay-node#readme",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.4.2",
    "terser": "^5.43.1",
    "vite": "^6.3.5",
    "vitest": "^2.1.8"
  }
}
